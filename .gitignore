# ── Dependencies ─────────────────────────────────────────────────
node_modules/

# ── Build outputs ────────────────────────────────────────────────
dist/
dist-ssr/
build/
out/
*.js.map
*.d.ts.map

# ── Environment & secrets ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── Electron packager output ──────────────────────────────────────
client/release/
client/out/

# ── TypeScript incremental build cache ───────────────────────────
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test coverage ────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Vite cache ───────────────────────────────────────────────────
.vite/
vite.config.ts.timestamp-*

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Editors ───────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Misc ──────────────────────────────────────────────────────────
*.local
.cache/

# ── npm package lock (monorepo uses workspaces — keep root lock only) ─────────
server/package-lock.json
client/package-lock.json
shared/package-lock.json

# ── Electron app config written at runtime ───────────────────────
# (stored in OS userData, but guard against any local copies)
config.json

# ── PostgreSQL local data dir (if ever run embedded for dev) ─────
pgdata/

# ── Misplaced directory (artefact — safe to keep ignored) ─────────
Users/
