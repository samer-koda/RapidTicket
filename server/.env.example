# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=rapidticket
DB_PASSWORD=rapidticket
DB_DATABASE=rapidticket

# ── Auth ──────────────────────────────────────────────────────────
# Generate a strong random secret, e.g.: openssl rand -hex 64
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h

# ── Server ────────────────────────────────────────────────────────
PORT=3000
